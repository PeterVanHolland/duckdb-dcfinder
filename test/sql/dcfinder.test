# name: test/sql/dcfinder.test
# description: Test DCFinder extension
# group: [sql]

require dcfinder

# Basic test with the employees table from the paper
statement ok
CREATE TABLE employees (
    name VARCHAR, phone VARCHAR, position VARCHAR,
    salary INTEGER, hired INTEGER
);

statement ok
INSERT INTO employees VALUES
    ('W. Jones', '202-222', 'Developer', 2000, 2012),
    ('B. Jones', '202-222', 'Developer', 3000, 2010),
    ('J. Miller', '202-333', 'Developer', 4000, 2010),
    ('D. Miller', '202-333', 'DBA', 8000, 2010),
    ('W. Jones', '202-555', 'DBA', 7000, 2010),
    ('W. Jones', '202-222', 'Developer', 1000, 2012);

# Should discover exact DCs
query I
SELECT count(*) > 0 FROM dcfinder('employees');
----
true

# Approximate threshold should find at least as many DCs
query I
SELECT (SELECT count(*) FROM dcfinder('employees', threshold := 0.1)) >= (SELECT count(*) FROM dcfinder('employees'));
----
true

# Simple two-column table for UCC discovery
statement ok
CREATE TABLE unique_test (a INTEGER, b INTEGER);

statement ok
INSERT INTO unique_test VALUES (1, 10), (2, 20), (3, 30);

# Should find NOT(t1.a = t2.a) as a UCC
query I
SELECT count(*) > 0 FROM dcfinder('unique_test') WHERE dc LIKE '%t1.a = t2.a%';
----
true

# Should find NOT(t1.b = t2.b) as a UCC
query I
SELECT count(*) > 0 FROM dcfinder('unique_test') WHERE dc LIKE '%t1.b = t2.b%';
----
true

# Test soundness column exists
query I
SELECT count(*) > 0 FROM dcfinder('employees') WHERE is_sound IS NOT NULL;
----
true

# Test soundness=false returns all DCs (including unsound)
query I
SELECT (SELECT count(*) FROM dcfinder('employees', soundness := false)) >= (SELECT count(*) FROM dcfinder('employees'));
----
true

# UCC constraints (single predicate) are always sound
query I
SELECT bool_and(is_sound) FROM dcfinder('unique_test') WHERE num_predicates = 1;
----
true

# Test with data that has genuinely dependent columns (FD: state -> tax_rate)
# Need enough rows for statistical soundness test to have power
statement ok
CREATE TABLE tax_rules AS
SELECT * FROM (VALUES
    ('CA', 7.25), ('CA', 7.25), ('CA', 7.25), ('CA', 7.25), ('CA', 7.25),
    ('CA', 7.25), ('CA', 7.25), ('CA', 7.25), ('CA', 7.25), ('CA', 7.25),
    ('NY', 8.00), ('NY', 8.00), ('NY', 8.00), ('NY', 8.00), ('NY', 8.00),
    ('NY', 8.00), ('NY', 8.00), ('NY', 8.00), ('NY', 8.00), ('NY', 8.00),
    ('TX', 0.00), ('TX', 0.00), ('TX', 0.00), ('TX', 0.00), ('TX', 0.00),
    ('TX', 0.00), ('TX', 0.00), ('TX', 0.00), ('TX', 0.00), ('TX', 0.00),
    ('FL', 6.00), ('FL', 6.00), ('FL', 6.00), ('FL', 6.00), ('FL', 6.00),
    ('FL', 6.00), ('FL', 6.00), ('FL', 6.00), ('FL', 6.00), ('FL', 6.00)
) t(state, tax_rate);

# Should discover the FD state -> tax_rate as a sound DC
query I
SELECT count(*) > 0 FROM dcfinder('tax_rules') WHERE is_sound AND dc LIKE '%state%' AND dc LIKE '%tax_rate%';
----
true
